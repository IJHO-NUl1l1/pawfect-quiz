# 이 파일을 복사해서 .env.local 로 만들고 실제 값을 채우세요.
# .env.local 은 커밋되지 않습니다.

# The Dog API (https://thedogapi.com) — 데이터 파이프라인 재실행 시에만 필요 (런타임 불필요)
DOG_API_KEY=

# 배포 절대 URL — OG 미리보기·공유 링크에 사용 (예: https://pawfect-quiz.vercel.app)
# 미설정 시 클라이언트는 window.origin으로 폴백하지만, 카톡/OG는 절대 URL이 필요.
NEXT_PUBLIC_SITE_URL=

# 카카오 JavaScript 키 — 카톡 공유용. https://developers.kakao.com 앱 생성 후
# JavaScript 키를 넣고, 앱 설정 > 플랫폼 > Web 사이트 도메인에 배포 도메인을 등록할 것.
# 미설정 시 카톡 공유 버튼만 비활성화된다.
NEXT_PUBLIC_KAKAO_JS_KEY=

# Supabase — (후순위) 결과 통계·피드용. 현재 공유는 DB 없이 URL 인코딩으로 동작.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
